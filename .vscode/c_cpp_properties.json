{
    "configurations": [
        {
            "name": "Cygwin",
            "compilerPath": "C:/cygwin64/bin/gcc.exe",
            "cStandard": "c17",
            "intelliSenseMode": "linux-gcc-x64",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/src/gui",
                "${workspaceFolder}/src/gui/web",
                "${workspaceFolder}/include",
                "${workspaceFolder}/lib/mongoose"
            ],
            "defines": [
                "__CYGWIN__"
            ],
            "env": {
                "PATH": "C:/cygwin64/bin;${env:PATH}"
            }
        }
    ],
    "version": 4
}
